# Scrutator Environment Variables

# OpenRouter API (free tier)
OPENROUTER_API_KEY=your_openrouter_api_key_here

# Optional: Telegram Bot Token (if using Telegram)
TELEGRAM_BOT_TOKEN=

# Optional: OpenAI API Key (if you want to use OpenAI models)
OPENAI_API_KEY=

# Optional: Anthropic API Key
ANTHROPIC_API_KEY=

# Path to ChromaDB persistent directory (optional)
CHROMA_PERSIST_DIR=./chroma_db

# Logging level
LOG_LEVEL=INFO
