# Scrutator Academic Environment Variables
# Copy this file to .env and fill in your actual keys

# OpenRouter API (free tier) – sign up at https://openrouter.ai
OPENROUTER_API_KEY=your_openrouter_api_key_here

# Optional: CORE API (for PDF fallback) – sign up at https://core.ac.uk
CORE_API_KEY=your_core_api_key_here

# Optional: Telegram Bot Token (if using Telegram integration)
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here

# Optional: REST API authentication key (auto-generated if not set)
SCRUTATOR_API_KEY=your_api_key_here

# Optional: User email for polite API usage (academic sources)
USER_EMAIL=your_email@example.com

# Optional: CORS allowed origins (comma-separated)
CORS_ORIGINS=http://localhost:7860,https://yourdomain.com

# Optional: Logging level (DEBUG, INFO, WARNING, ERROR)
LOG_LEVEL=INFO
